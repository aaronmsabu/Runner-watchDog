# GitHub Personal Access Token (repo, workflow, admin:org)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Target repository URL for runner registration
REPO_URL=https://github.com/your-org/your-repo

# Redis connection
REDIS_HOST=redis
REDIS_PORT=6379

# Current runner version (used as baseline)
RUNNER_VERSION=2.329.0

# Rolling update config — percentage of fleet to replace per cycle
UPDATE_BATCH_PERCENT=10

# How often the watchdog checks for updates (in seconds)
CHECK_INTERVAL_SECONDS=3600
